[Unit]
Description=WireGuard API Server
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/wg-bot
EnvironmentFile=/opt/wg-bot/.env
ExecStart=/opt/wg-bot/venv/bin/uvicorn main:app --host 127.0.0.1 --port 8000
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
